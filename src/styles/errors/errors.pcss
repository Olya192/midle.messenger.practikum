.error {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;

  & h1 {
    font-size: 40px;
    margin: 0 0 20px;
  }

  & h2 {
    font-size: 20px;
    margin: 0;
  }

  & a {
    text-decoration: none;
    color: #3369f3;
    margin-top: 69px;
    font-size: 11px;
  }
}
